<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing student</h1>

  <%= render "form", student: @student %>

  <%= link_to "Show this student", program_student_path(@student_program, @student), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
  <%= link_to "Back to students", program_students_path(@student_program), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
</div>
